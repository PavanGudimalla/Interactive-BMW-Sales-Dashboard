                "verticalAlign": "top",
                "marginLeft": "2%",
                "backgroundColor": DASH_BG,
                "border": "1px solid #1f3b5b",
                "padding": "15px",
                "borderRadius": "8px",
                "boxSizing": "border-box"
            }),
        ], style={"whiteSpace": "nowrap"})   
    ]
)

# callbacks

@app.callback(
    Output("year_dropdown", "options"),
    Output("year_dropdown", "value"),
    Input("region_radio", "value")
)
def set_year_options(sel_region):
    dff = df[df["Region"] == sel_region]
    years = sorted(dff["Year"].unique())
    options = [{"label": int(y), "value": int(y)} for y in years]
    value = years[0] if years else None
    return options, value


@app.callback(
    Output("model_dropdown", "options"),
    Output("model_dropdown", "value"),
    Input("region_radio", "value"),
    Input("year_dropdown", "value")
)
def set_model_options(sel_region, sel_year):
    if sel_year is None:
        return [], []
    dff = df[(df["Region"] == sel_region) & (df["Year"] == sel_year)]
    models = sorted(dff["Model"].unique())
    options = [{"label": m, "value": m} for m in models]
    return options, models

# Viz 1 and Viz 2

@app.callback(
    Output("viz1", "figure"),
    Output("viz2", "figure"),
    Input("region_radio", "value"),
    Input("year_dropdown", "value"),
    Input("model_dropdown", "value")
)
def update_viz1_viz2(region, year, models):
    if year is None or not models:
        fig_empty = go.Figure()
        fig_empty.update_layout(
            title="Select region, year, and at least one model.",
            plot_bgcolor=DASH_BG,
            paper_bgcolor=DASH_BG,
            font=BASE_FONT,
            title_font=TITLE_FONT
        )
        return fig_empty, fig_empty

    dff = df[(df["Region"] == region) & (df["Year"] == year)]
    dff = dff[dff["Model"].isin(models)]

    if dff.empty:
        fig_empty = go.Figure()
        fig_empty.update_layout(
            title="No data for this selection.",
            plot_bgcolor=DASH_BG,
            paper_bgcolor=DASH_BG,
            font=BASE_FONT,
            title_font=TITLE_FONT
        )
        return fig_empty, fig_empty

    agg = (dff
           .groupby("Model", as_index=False)
           .agg({"Sales_Volume": "sum", "Price_USD": "mean"})
           .sort_values("Sales_Volume", ascending=False))

    # bar + line
    fig1 = go.Figure()
    fig1.add_bar(
        x=agg["Model"],
        y=agg["Sales_Volume"],
        name="Sales volume",
        marker_color=BAR_COLOR
    )
    fig1.add_scatter(
        x=agg["Model"],
        y=agg["Price_USD"],
        name="Average price (USD)",
        mode="lines+markers",
        yaxis="y2",
        line=dict(color=LINE_COLOR)
    )
    fig1.update_layout(
        title=f"Sales volume and average price by model – {region}, {year}",
        xaxis_title="Model",
        yaxis_title="Sales volume (units)",
        yaxis2=dict(
            title="Average price (USD)",
            overlaying="y",
            side="right"
        ),
        plot_bgcolor=DASH_BG,
        paper_bgcolor=DASH_BG,
        font=BASE_FONT,
        title_font=TITLE_FONT,
        xaxis=dict(gridcolor=GRID_COLOR),
        yaxis=dict(gridcolor=GRID_COLOR),
        legend=dict(font=BASE_FONT)
    )

    # pie chart
    fig2 = px.pie(
        agg,
        names="Model",
        values="Sales_Volume",
        title=f"Model sales share – {region}, {year}",
        hole=0.4
    )
    fig2.update_layout(
        plot_bgcolor=DASH_BG,
        paper_bgcolor=DASH_BG,
        font=BASE_FONT,
        title_font=TITLE_FONT,
        legend=dict(font=BASE_FONT)
    )

    return fig1, fig2


# Viz 3: transmission vs region

@app.callback(
    Output("viz3", "figure"),
    Input("trans_check", "value")
)
def update_viz3(trans_list):
    if not trans_list:
        fig = go.Figure()
        fig.update_layout(
            title="Select at least one transmission type.",
            plot_bgcolor=DASH_BG,
            paper_bgcolor=DASH_BG,
            font=BASE_FONT,
            title_font=TITLE_FONT
        )
        return fig

    dff = df[df["Transmission"].isin(trans_list)]
    g3 = dff.groupby(["Region", "Transmission"], as_index=False)["Sales_Volume"].sum()

    fig3 = px.bar(
        g3,
        x="Region",
        y="Sales_Volume",
        color="Transmission",
        barmode="group",
        title="Sales volume by region and transmission",
        labels={"Sales_Volume": "Sales volume (units)"}
    )
    fig3.update_layout(
        plot_bgcolor=DASH_BG,
        paper_bgcolor=DASH_BG,
        font=BASE_FONT,
        title_font=TITLE_FONT,
        xaxis=dict(gridcolor=GRID_COLOR),
        yaxis=dict(gridcolor=GRID_COLOR),
        legend=dict(font=BASE_FONT)
    )
    return fig3

# Viz 4: fuel type heatmap
@app.callback(
    Output("viz4", "figure"),
    Input("fuel_check", "value")
)
def update_viz4(fuel_list):
    if not fuel_list:
        fig = go.Figure()
        fig.update_layout(
            title="Select at least one fuel type.",
            plot_bgcolor=DASH_BG,
            paper_bgcolor=DASH_BG,
            font=BASE_FONT,
            title_font=TITLE_FONT
        )
        return fig

    dff = df[df["Fuel_Type"].isin(fuel_list)]
    g4 = dff.groupby(["Fuel_Type", "Year"], as_index=False)["Sales_Volume"].sum()

    pivot = g4.pivot(index="Fuel_Type", columns="Year", values="Sales_Volume")

    fig4 = px.imshow(
        pivot,
        labels={"x": "Year", "y": "Fuel type", "color": "Sales volume (units)"},
        title="Sales volume trend by fuel type over time"
    )
    fig4.update_layout(
        plot_bgcolor=DASH_BG,
        paper_bgcolor=DASH_BG,
        font=BASE_FONT,
        title_font=TITLE_FONT,
        legend=dict(font=BASE_FONT)
    )
    return fig4



# Viz 5: price vs sales volume, year range

@app.callback(
    Output("viz5", "figure"),
    Input("region_radio", "value"),
    Input("model_dropdown", "value"),
    Input("year_range", "value")
)
def update_viz5(region, models, year_range):
    if not models:
        fig = go.Figure()
        fig.update_layout(
            title="Select at least one model.",
            plot_bgcolor=DASH_BG,
            paper_bgcolor=DASH_BG,
            font=BASE_FONT,
            title_font=TITLE_FONT
        )
        return fig

    year_min, year_max = year_range
    dff = df[
        (df["Region"] == region) &
        (df["Model"].isin(models)) &
        (df["Year"] >= year_min) &
        (df["Year"] <= year_max)
    ]

    if dff.empty:
        fig = go.Figure()
        fig.update_layout(
            title="No data for this selection.",
            plot_bgcolor=DASH_BG,
            paper_bgcolor=DASH_BG,
            font=BASE_FONT,
            title_font=TITLE_FONT
        )
        return fig

    agg = (
        dff.groupby("Model", as_index=False)
           .agg({"Sales_Volume": "sum", "Price_USD": "mean"})
    )

    min_vol = agg["Sales_Volume"].min()
    agg["SizeScaled"] = (agg["Sales_Volume"] - min_vol) + 1

    fig5 = px.scatter(
        agg,
        x="Price_USD",
        y="Sales_Volume",
        color="Model",
        size="SizeScaled",
        size_max=80,
        title=f"Price vs sales volume – {region}, {year_min}–{year_max}",
        labels={
            "Price_USD": "Average price (USD)",
            "Sales_Volume": "Sales volume (units)"
        }
    )

    fig5.update_traces(marker=dict(sizemode="area"))

    fig5.update_layout(
        plot_bgcolor=DASH_BG,
        paper_bgcolor=DASH_BG,
        font=BASE_FONT,
        title_font=TITLE_FONT,
        xaxis=dict(gridcolor=GRID_COLOR),
        yaxis=dict(gridcolor=GRID_COLOR),
        legend=dict(font=BASE_FONT)
    )

    return fig5


