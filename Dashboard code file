Interactive Dashboard
import pandas as pd
import plotly.express as px
import plotly.graph_objects as go
from dash import Dash, dcc, html, Input, Output

# BMW dataset
df = pd.read_csv("BMW sales data (2010-2024).csv")
df["Year"] = df["Year"].astype(int)

regions = sorted(df["Region"].unique())
transmissions = sorted(df["Transmission"].unique())
fuel_types = sorted(df["Fuel_Type"].unique())
years_sorted = sorted(df["Year"].unique())

DASH_BG = "#102840"     
GRID_COLOR = "#2b3f5f"
FONT_COLOR = "white"
BAR_COLOR = "#1f77b4"    
LINE_COLOR = "#ff7f0e"   
BASE_FONT = dict(color=FONT_COLOR, size=12, family="Arial")
TITLE_FONT = dict(color=FONT_COLOR, size=14, family="Arial")

# layout
app = Dash(__name__)

app.layout = html.Div(
    style={
        "backgroundColor": "#0B1E33",
        "padding": "20px",
        "fontFamily": "Arial, sans-serif"
    },
    children=[
        # Title 
        html.Div([
            html.H1("BMW Sales Dashboard", style={"margin": "0", "color": "white"}),
            html.P(
                "BMW global sales analysis by region, model, fuel type, and transmission (2010–2024)",
                style={"color": "white", "margin": "4px 0 0 0", "fontSize": "12px"}
            )
        ], style={
            "backgroundColor": "#013A63",
            "border": "2px solid #0F4C81",
            "padding": "10px 20px",
            "marginBottom": "20px",
            "borderRadius": "8px"
        }),

        # MAIN Layout Rows
        html.Div([
            # LEFT: visualizations
            html.Div([
                # Row 1: Viz 1 and Viz 2
                html.Div([
                    html.Div([
                        html.H3("Viz 1: Sales volume and average price by model",
                                style={"color": "white"}),
                        dcc.Graph(id="viz1"),
                    ], style={"width": "50%", "display": "inline-block",
                              "verticalAlign": "top"}),

                    html.Div([
                        html.H3("Viz 2: Model market share",
                                style={"color": "white"}),
                        dcc.Graph(id="viz2"),
                    ], style={"width": "50%", "display": "inline-block",
                              "verticalAlign": "top"}),
                ], style={"marginBottom": "10px"}),

                # Row 2: Viz 3 and Viz 4
                html.Div([
                    html.Div([
                        html.H3("Viz 3: Sales volume by region and transmission",
                                style={"color": "white"}),
                        dcc.Graph(id="viz3"),
                    ], style={"width": "50%", "display": "inline-block",
                              "verticalAlign": "top"}),

                    html.Div([
                        html.H3("Viz 4: Fuel type sales trend over time",
                                style={"color": "white"}),
                        dcc.Graph(id="viz4"),
                    ], style={"width": "50%", "display": "inline-block",
                              "verticalAlign": "top"}),
                ], style={"marginBottom": "10px"}),

                # Row 3: Viz 5 + slider
                html.Div([
                    html.H3("Viz 5: Price vs sales volume by model",
                            style={"color": "white"}),
                    html.Label("Year range (for Viz 5)",
                               style={"color": "white"}),
                    dcc.RangeSlider(
                        id="year_range",
                        min=int(years_sorted[0]),
                        max=int(years_sorted[-1]),
                        value=[int(years_sorted[0]), int(years_sorted[-1])],
                        marks={int(y): str(int(y)) for y in years_sorted},
                        step=None
                    ),
                    dcc.Graph(id="viz5"),
                ], style={"marginTop": "10px"}),
            ], style={
                "width": "68%",                
                "display": "inline-block",
                "verticalAlign": "top",
                "backgroundColor": DASH_BG,
                "border": "1px solid #1f3b5b",
                "padding": "15px",
                "borderRadius": "8px",
                "color": "white",
                "boxSizing": "border-box"
            }),

            # RIGHT: filters and BMW logo
            html.Div([
                html.H3("Filters", style={"color": "white"}),

                html.Img(
                    src="https://upload.wikimedia.org/wikipedia/commons/4/44/BMW.svg",
                    style={"width": "80px", "marginBottom": "10px"}
                ),

                html.H4("Region", style={"color": "white"}),
                dcc.RadioItems(
                    id="region_radio",
                    options=[{"label": r, "value": r} for r in regions],
                    value=regions[0],
                    labelStyle={"display": "block", "color": "white"}
                ),

                html.H4("Year", style={"color": "white"}),
                dcc.Dropdown(
                    id="year_dropdown",
                    options=[],
                    value=None,
                    clearable=False,
                    style={"backgroundColor": "#f0f0f0", "color": "black"}
                ),

                html.H4("Model", style={"color": "white"}),
                dcc.Dropdown(
                    id="model_dropdown",
                    options=[],
                    value=[],
                    multi=True,
                    style={"backgroundColor": "#f0f0f0", "color": "black"}
                ),

                html.H4("Transmission (for Viz 3)", style={"color": "white"}),
                dcc.Checklist(
                    id="trans_check",
                    options=[{"label": t, "value": t} for t in transmissions],
                    value=transmissions,
