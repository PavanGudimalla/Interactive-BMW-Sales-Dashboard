Visualization 1 - Sales Volume and Avg Price by Model
region = "Europe"
year = 2020
models = ["3 Series", "5 Series"]

# Aggregation
dff = df[(df["Region"] == region) & (df["Year"] == year)]
dff = dff[dff["Model"].isin(models)]

agg_viz1 = (
    dff.groupby("Model", as_index=False)
       .agg({"Sales_Volume": "sum", "Price_USD": "mean"})
       .sort_values("Sales_Volume", ascending=False)
)

# Plot
fig1 = go.Figure()
fig1.add_bar(x=agg_viz1["Model"], y=agg_viz1["Sales_Volume"], name="Sales volume")
